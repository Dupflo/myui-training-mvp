{
  "kind": "collectionType",
  "collectionName": "programs",
  "info": {
    "singularName": "program",
    "pluralName": "programs",
    "displayName": "Programmes",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "program_model": {
      "type": "dynamiczone",
      "components": [
        "program-models.modules",
        "program-models.ressources"
      ],
      "min": 1
    },
    "product_id": {
      "type": "string"
    },
    "connected_accounts": {
      "displayName": "Connected Account",
      "type": "component",
      "repeatable": true,
      "component": "stripe.connected-account"
    },
    "transactional": {
      "displayName": "Brevo",
      "type": "component",
      "repeatable": false,
      "component": "transactional.brevo"
    },
    "landing_pages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::landing-page.landing-page",
      "mappedBy": "program"
    },
    "creator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
